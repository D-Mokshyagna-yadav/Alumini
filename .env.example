# ─── Server Environment Variables ───────────────────────────
# Copy this file to .env and fill in the values.

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/alumni_association

# Session secret (use a random long string in production)
SESSION_SECRET=change_me_to_a_random_string

# Node environment: "development" or "production"
# In production: console logs are silenced, cookies are secure, CORS is restricted
NODE_ENV=development

# Port the server listens on (default: 5000)
PORT=5000

# ─── CORS / URL ─────────────────────────────────────────────
# Comma-separated list of allowed origins (only enforced when set).
# Leave empty in dev to allow all origins (LAN access).
# Example: https://alumni.example.com,https://www.alumni.example.com
ALLOWED_ORIGINS=

# Canonical frontend URL (used in email links, etc.)
# In production set this to your actual domain.
WEBSITE_URL=http://localhost:5173

# ─── Gmail SMTP (for OTP / notification emails) ─────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Client Environment Variables (Vite) ────────────────────
# These go in client/.env (prefixed with VITE_)
#
# Socket.io server URL. Leave empty when the API and client are
# served from the same origin (single-instance deployment).
# Only set this if the socket server is on a different domain/port.
# VITE_SOCKET_URL=https://api.alumni.example.com
